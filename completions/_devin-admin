#compdef devin-admin

# zsh completion for devin-admin
# Keep in sync with src/cli/commands/*.ts and src/cli/index.ts whenever
# commands, subcommands, or flags change.

_devin_admin_global_flags=(
  '--json[output raw JSON instead of tables]'
  '--dry-run[print the intended API request without executing it]'
)

_devin-admin() {
  local -a commands
  commands=(
    'orgs:organization cache'
    'acu:ACU limits'
    'membership:org membership'
    'monitor:consumption monitoring'
  )

  _arguments -C \
    $_devin_admin_global_flags \
    '1: :->command' \
    '*::arg:->args'

  case $state in
    command)
      _describe 'command' commands
      ;;
    args)
      case $words[1] in
        orgs)
          local -a orgs_subcommands
          orgs_subcommands=(
            'get:get a single org'
            'list:list cached orgs'
            'refresh:force refresh from API'
          )
          _arguments -C \
            $_devin_admin_global_flags \
            '1: :->orgs_command' \
            '*::arg:->orgs_args'
          case $state in
            orgs_command) _describe 'orgs subcommand' orgs_subcommands ;;
            orgs_args)
              case $words[1] in
                list) _arguments $_devin_admin_global_flags '--refresh[force refresh from API]' ;;
              esac
              ;;
          esac
          ;;
        acu)
          local -a acu_subcommands
          acu_subcommands=(
            'get-org:get an org ACU limit'
            'set-org:set an org ACU limit'
            'clear-org:clear an org ACU limit'
            'get-user:get a user ACU limit'
            'set-user:set a user ACU limit'
            'clear-user:clear a user ACU limit'
            'get-default:get the enterprise default limit'
            'set-default:set the enterprise default limit'
          )
          _arguments -C \
            $_devin_admin_global_flags \
            '1: :->acu_command' \
            '*::arg:->acu_args'
          case $state in
            acu_command) _describe 'acu subcommand' acu_subcommands ;;
            acu_args)
              case $words[1] in
                set-org)
                  _arguments $_devin_admin_global_flags \
                    '--local=[local ACU limit]:n' \
                    '--cloud=[cloud ACU limit]:n'
                  ;;
                set-user)
                  _arguments $_devin_admin_global_flags \
                    '--local=[local ACU limit]:n' \
                    '--billing-org=[billing org]:org'
                  ;;
                set-default)
                  _arguments $_devin_admin_global_flags \
                    '--local=[local ACU limit]:n'
                  ;;
              esac
              ;;
          esac
          ;;
        membership)
          local -a membership_subcommands
          membership_subcommands=(
            'get-user:get a user'"'"'s membership'
            'set-billing-org:set a user'"'"'s billing org'
            'assign:add a user to an org'
            'set-only:set exactly one org for a user'
          )
          _arguments -C \
            $_devin_admin_global_flags \
            '1: :->membership_command' \
            '*::arg:->membership_args'
          case $state in
            membership_command) _describe 'membership subcommand' membership_subcommands ;;
            membership_args)
              case $words[1] in
                set-billing-org)
                  _arguments $_devin_admin_global_flags '--billing-org=[billing org]:org'
                  ;;
                assign)
                  _arguments $_devin_admin_global_flags \
                    '--org=[org]:org' \
                    '--role=[role]:role'
                  ;;
                set-only)
                  _arguments $_devin_admin_global_flags '--org=[org]:org'
                  ;;
              esac
              ;;
          esac
          ;;
        monitor)
          local -a monitor_subcommands
          monitor_subcommands=(
            'org:enterprise-wide ACUs vs an org'"'"'s cycle limit'
            'user:per-user ACU breakdown by product'
          )
          _arguments -C \
            $_devin_admin_global_flags \
            '1: :->monitor_command' \
            '*::arg:->monitor_args'
          case $state in
            monitor_command) _describe 'monitor subcommand' monitor_subcommands ;;
            monitor_args)
              case $words[1] in
                org|user)
                  _arguments $_devin_admin_global_flags '--month=[month, YYYY-MM]:month'
                  ;;
              esac
              ;;
          esac
          ;;
      esac
      ;;
  esac
}

_devin-admin "$@"
